@model IEnumerable<PlataformaCreditos.Models.SolicitudCredito>

@{
    ViewData["Title"] = "Mis Solicitudes";
}

<h1>Mis Solicitudes de Crédito</h1>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p>
    <a asp-action="Crear" class="btn btn-primary">Nueva Solicitud</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Monto Solicitado</th>
            <th>Fecha</th>
            <th>Estado</th>
            <th>Motivo</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Id</td>
            <td>@item.MontoSolicitado.ToString("C")</td>
            <td>@item.FechaSolicitud.ToString("dd/MM/yyyy")</td>
            <td>
                @switch (item.Estado)
                {
                    case PlataformaCreditos.Models.EstadoSolicitud.Pendiente:
                        <span class="badge bg-warning">Pendiente</span>
                        break;
                    case PlataformaCreditos.Models.EstadoSolicitud.Aprobado:
                        <span class="badge bg-success">Aprobado</span>
                        break;
                    case PlataformaCreditos.Models.EstadoSolicitud.Rechazado:
                        <span class="badge bg-danger">Rechazado</span>
                        break;
                }
            </td>
            <td>@item.MotivoRechazo</td>
        </tr>
}
    </tbody>
</table>