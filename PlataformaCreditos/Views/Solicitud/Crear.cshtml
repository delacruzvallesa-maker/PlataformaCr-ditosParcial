@model PlataformaCreditos.Models.SolicitudCredito

@{
    ViewData["Title"] = "Nueva Solicitud de Crédito";
    var montoMaximo = ViewData["MontoMaximo"] as decimal? ?? 0;
    var ingresos = ViewData["IngresosMensuales"] as decimal? ?? 0;
}

<h1>Nueva Solicitud de Crédito</h1>

<div class="alert alert-info">
    <strong>Ingresos mensuales:</strong> @ingresos.ToString("C")<br />
    <strong>Monto máximo permitido:</strong> @montoMaximo.ToString("C") (5 veces tus ingresos)
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="Crear">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" name="ClienteId" value="@ViewData["ClienteId"]" />
            <div class="form-group mb-3">
                <label asp-for="MontoSolicitado" class="control-label"></label>
                <input asp-for="MontoSolicitado" class="form-control" />
                <span asp-validation-for="MontoSolicitado" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Enviar Solicitud" class="btn btn-primary" />
                <a asp-action="MisSolicitudes" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}